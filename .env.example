# ODE reads these values from the process environment. This file is an example only.
ODE_MONITORING_DCIM_BASE_URL=https://dcim.example.invalid
ODE_MONITORING_RULES_DIR=C:\path\outside-git\monitoring-rules
ODE_MONITORING_EDGE_PROFILE_DIR=C:\path\outside-git\edge-profile
ODE_MONITORING_HEADLESS=false
ODE_MONITORING_COLLECT_DCIM=true
ODE_MONITORING_DEV_MOCK=false

# Knowledge base attachments. Keep the directory outside Git and include it in backups.
ODE_KNOWLEDGE_UPLOAD_DIR=C:\path\outside-git\knowledge-uploads
ODE_KNOWLEDGE_MAX_ATTACHMENT_MB=15
